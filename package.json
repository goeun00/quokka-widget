{
  "name": "quokka-widget",
  "version": "1.0.0",
  "description": "쿼카 큐비 Jira 비서 위젯",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.example.app",
    "publish": [
      {
        "provider": "github",
        "owner": "goeun00",
        "repo": "quokka-widget"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "electron-updater": "^6.8.3",
    "p-limit": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
